# ─────────────────────────────────────────────────────────────
#  CampusShield AI — Environment Variables
#  Copy to .env and fill in real values before running.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_32_CHAR_RANDOM_SECRET
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=campusshield
POSTGRES_USER=campusshield_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://campusshield_user:CHANGE_ME_DB_PASSWORD@postgres:5432/campusshield

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_64_CHAR_MIN
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_MICROSOFT_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/callback

# ── ML Microservice ──────────────────────────────────────────
ML_SERVICE_URL=http://ml_service:8001
ML_SERVICE_API_KEY=CHANGE_ME_ML_INTERNAL_API_KEY

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ── Differential Privacy ─────────────────────────────────────
DP_EPSILON=1.0                        # Privacy budget per snapshot
DP_SENSITIVITY=1                      # L1 sensitivity of count queries

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CampusShield AI
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000
